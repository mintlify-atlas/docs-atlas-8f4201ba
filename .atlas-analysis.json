  "keyFeatures": [
    "Module system with 8 categories (Combat, Movement, Player, Render, World, Exploit, Misc, Fun)",
    "Advanced scripting API with GraalVM polyglot support",
    "Configuration system with auto-config and cloud sync",
    "Custom UI theme system built with Svelte",
    "Account management with OAuth authentication",
    "Cosmetics and marketplace integration",
    "Deep learning integration for AI-powered features",
    "Event-driven architecture with comprehensive event system",
    "Rotation and combat management utilities",
    "Integration with modern Fabric mods (ViaFabricPlus, Sodium, Lithium)"
  ],
  "publicApiSurface": [
    "ClientModule - Base class for creating modules",
    "ModuleManager - Manages all registered modules",
    "CommandManager - Handles command registration and execution",
    "EventManager - Event system for handling game events",
    "ConfigSystem - Configuration management and persistence",
    "ScriptManager - Script loading and execution",
    "RotationManager - Player rotation management",
    "CombatManager - Combat state tracking",
    "InventoryManager - Inventory operations",
    "AccountManager - Minecraft account management",
    "MarketplaceManager - Script and config marketplace",
    "CosmeticService - Cosmetic features (capes, etc.)",
    "ThemeManager - UI theme customization",
    "AutoConfig - Cloud configuration sync",
    "ModuleCategories - Module category registry"
  ]
